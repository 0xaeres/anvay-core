# Copy to .env and fill in. Never commit the real file.

# ---- Cloud LLM provider (production council, PR review, changelog) ----
DEEPINFRA_API_KEY=

# ---- Source connectors ----
GITHUB_TOKEN=
# CONFLUENCE_TOKEN=
# SLACK_TOKEN=

# ---- Webhooks ----
GITHUB_WEBHOOK_SECRET=

# ---- Neo4j (matches docker-compose defaults) ----
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexuslocal

# ---- Langfuse (matches docker-compose defaults) ----
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_NEXTAUTH_SECRET=changeme-local-only-32-chars-abc
LANGFUSE_SALT=changeme-local-only-32-chars-xyz

# ---- Optional showcase provider ----
# ANTHROPIC_API_KEY=

# ---- Encryption key — REQUIRED for secrets at rest ----
# Encrypts connector tokens (GitHub PATs, API keys) and Atlassian OAuth tokens
# stored in SQLite. Without this, secrets are stored in plaintext.
# Generate with:
#   uv run python -c "from nexus.auth.token_cipher import TokenCipher; print(TokenCipher.generate_key())"
NEXUS_TOKEN_KEY=

# ---- Assistant layer — Atlassian OAuth (docs/ASSISTANT-LAYER.md) ----
# OAuth app credentials from https://developer.atlassian.com/console/myapps/
# ATLASSIAN_CLIENT_ID=
# ATLASSIAN_CLIENT_SECRET=
