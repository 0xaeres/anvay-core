# Copy to .env and fill in. Never commit the real file.

# ---- Cloud LLM provider (council + light/enricher) ----
LLM_API_KEY=

# ---- Org skills repo (REQUIRED) ----
# Both must be set before starting the server. ANVAY_SKILLS_REPO is the HTTPS
# clone URL of the org-wide skills repository. ANVAY_SKILLS_REPO_TOKEN is a
# GitHub PAT with `repo` scope (add `write:org` if the repo is under a GitHub
# org). This is NOT the product source token entered during product onboarding.
ANVAY_SKILLS_REPO=https://github.com/myorg/anvay-skills.git
ANVAY_SKILLS_REPO_TOKEN=

# ---- Optional static source connectors ----
# Only needed when declaring static GitHub connectors in anvay.yaml. Product
# onboarding collects its own per-product source PAT in the UI.
GITHUB_TOKEN=

# ---- Encryption key — REQUIRED for connector secrets at rest ----
# Encrypts connector tokens stored in SQLite. Without this, secrets are
# stored in plaintext.
# Generate with:
#   uv run python -c "from anvay.auth.token_cipher import TokenCipher; print(TokenCipher.generate_key())"
ANVAY_TOKEN_KEY=

# ---- Deployed password/session security ----
# Local dev: leave ANVAY_ENV unset unless you want production config validation.
# Production: set ANVAY_ENV=production and use strong generated secrets.
ANVAY_ENV=
ANVAY_SECRET_KEY=
ANVAY_ADMIN_API_KEY=
ANVAY_BOOTSTRAP_ADMIN_EMAIL=
ANVAY_BOOTSTRAP_ADMIN_PASSWORD=
ANVAY_ALLOWED_ORIGINS=http://localhost:3000
ANVAY_ENABLE_LOCAL_FS_SOURCES=false

# ---- Oracle/Caddy deployment ----
ANVAY_API_DOMAIN=api.example.com

# ---- Optional free-tier observability ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
ANVAY_TRACE_CONTENT=false
