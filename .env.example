# Copy to .env and fill in. Never commit the real file.

# ---- Cloud LLM provider (council + light/enricher) ----
DEEPINFRA_API_KEY=

# ---- Source connectors ----
GITHUB_TOKEN=

# ---- Encryption key — REQUIRED for connector secrets at rest ----
# Encrypts connector tokens stored in SQLite. Without this, secrets are
# stored in plaintext.
# Generate with:
#   uv run python -c "from nexus.auth.token_cipher import TokenCipher; print(TokenCipher.generate_key())"
NEXUS_TOKEN_KEY=

# ---- Deployed auth/session security ----
# Any non-empty value enables API auth middleware.
NEXUS_SECRET_KEY=
NEXUS_ADMIN_API_KEY=
NEXUS_BOOTSTRAP_ADMIN_EMAIL=
NEXUS_BOOTSTRAP_ADMIN_PASSWORD=
NEXUS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Oracle/Caddy deployment ----
NEXUS_API_DOMAIN=api.example.com
NEXUS_SKILLS_REPO=

# ---- Optional free-tier observability ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
NEXUS_TRACE_CONTENT=false
